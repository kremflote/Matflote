@backend_HostAddress = http://localhost:5132

GET {{backend_HostAddress}}/health
Accept: application/json

###

GET {{backend_HostAddress}}/api/ingredients
Accept: application/json

###

GET {{backend_HostAddress}}/api/brands
Accept: application/json

###

GET {{backend_HostAddress}}/api/recipes
Accept: application/json

###

GET {{backend_HostAddress}}/api/mealplans?from=2026-07-01&to=2026-07-31
Accept: application/json

###

POST {{backend_HostAddress}}/api/ingredients
Content-Type: application/json

{
  "ingredientName": "Chicken thigh",
  "description": "Dark chicken cut with more fat and stronger flavor than chicken breast.",
  "brandId": null,
  "price": 79.90,
  "tags": ["Chicken"],
  "nutritionPer100": null,
  "color": "#e8b48f"
}

###

POST {{backend_HostAddress}}/api/recipes
Content-Type: application/json

{
  "recipeType": "Side",
  "name": "Simple rice",
  "imageUrl": null,
  "description": "Plain boiled rice.",
  "instructions": "Rinse rice and boil until tender.",
  "ingredients": [
    {
      "ingredientId": 4,
      "amount": 250,
      "unit": "Gram"
    }
  ],
  "tags": ["Dinner"],
  "dessertType": null
}

###

POST {{backend_HostAddress}}/api/mealplans
Content-Type: application/json

{
  "date": "2026-07-01",
  "slot": "Dinner",
  "notes": null,
  "recipes": [
    {
      "recipeId": 2,
      "role": "Main",
      "sortOrder": 0
    },
    {
      "recipeId": 1,
      "role": "Sauce",
      "sortOrder": 1
    },
    {
      "recipeId": 3,
      "role": "Side",
      "sortOrder": 2
    }
  ]
}

